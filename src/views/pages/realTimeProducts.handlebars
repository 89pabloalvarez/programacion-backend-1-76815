<div class="product-form">
  <form id="productCreate" class="formProducto">
    <h3>Crear Nuevo Producto</h3>

    <label for="title">Nombre</label>
    <input type="text" id="title" name="title" required />

    <label for="description">Descripción</label>
    <input type="text" id="description" name="description" required />

    <label for="price">Precio</label>
    <input type="number" id="price" name="price" step="0.01" required />

    <label for="stock">Stock</label>
    <input type="number" id="stock" name="stock" required />

    <label for="category">Categoría</label>
    <input type="text" id="category" name="category" required />

    <label for="thumbnails">Imágenes (una URL por línea)</label>
    <textarea id="thumbnails" name="thumbnails" rows="3"></textarea>

    <input type="submit" value="Crear" />
  </form>
</div>

<div id="products"></div>

<div id="pagination-controls">

  <div class="pagination-info" id="paginationInfo"></div>

  <div class="pagination-row">
    <button class="page-btn" id="prevBtn" disabled>← Anterior</button>

    <form class="page-jump-form" id="pageJumpForm">
      <label for="pageInput">Página:</label>
      <input id="pageInput" type="number" min="1" value="1" class="page-input" />
      <span class="page-total" id="pageTotalSpan">/ 1</span>
      <button type="submit" class="page-btn go-btn">Ir</button>
    </form>

    <button class="page-btn" id="nextBtn" disabled>Siguiente →</button>
  </div>

  <div class="pagination-row">
    <label for="limitSelect">Registros por página:</label>
    <select id="limitSelect" class="limit-select">
      <option value="5">5</option>
      <option value="10" selected>10</option>
      <option value="15">15</option>
      <option value="20">20</option>
      <option value="50">50</option>
    </select>
  </div>

</div>

<script src="/socket.io/socket.io.js"></script>
<script src="/realTimeProducts.js"></script>